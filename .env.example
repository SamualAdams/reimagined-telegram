# Azure DevOps Configuration
# Copy this file to .env and fill in your values

# Your Azure DevOps organization name (not the full URL)
# Example: if your org URL is https://dev.azure.com/contoso, use: contoso
AZURE_DEVOPS_ORG=your-organization-name

# Personal Access Token (PAT) for Azure DevOps
# Generate at: https://dev.azure.com/{organization}/_usersSettings/tokens
# Scope required: Work item (read & write)
AZURE_DEVOPS_PAT=your-personal-access-token
